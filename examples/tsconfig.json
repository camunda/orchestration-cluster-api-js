{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@camunda8/orchestration-cluster-api": ["../src/index.ts"],
      "@camunda8/orchestration-cluster-api/dist/runtime/errors": ["../src/runtime/errors.ts"]
    }
  },
  "include": ["./*.ts"]
}
